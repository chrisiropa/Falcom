<UserControl x:Class="KranSimulator.KranfahrtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F5F7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="Quelle" Target="{Binding ElementName=CmbSimulationSource}" />
                <ComboBox x:Name="CmbSimulationSource" SelectedIndex="0">
                    <ComboBoxItem Content="LKW1" />
                    <ComboBoxItem Content="LKW2" />
                    <ComboBoxItem Content="LKW3" />
                    <ComboBoxItem Content="BOX 1" />
                    <ComboBoxItem Content="BOX 2" />
                    <ComboBoxItem Content="BOX 3" />
                    <ComboBoxItem Content="BOX 4" />
                    <ComboBoxItem Content="BOX 5" />
                    <ComboBoxItem Content="BOX 6" />
                    <ComboBoxItem Content="BOX 7" />
                    <ComboBoxItem Content="BOX 8" />
                    <ComboBoxItem Content="BOX 9" />
                    <ComboBoxItem Content="BOX 10" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Label Content="Ziel" Target="{Binding ElementName=CmbSimulationTarget}" />
                <ComboBox x:Name="CmbSimulationTarget" SelectedIndex="10">
                    <ComboBoxItem Content="BOX 1" />
                    <ComboBoxItem Content="BOX 2" />
                    <ComboBoxItem Content="BOX 3" />
                    <ComboBoxItem Content="BOX 4" />
                    <ComboBoxItem Content="BOX 5" />
                    <ComboBoxItem Content="BOX 6" />
                    <ComboBoxItem Content="BOX 7" />
                    <ComboBoxItem Content="BOX 8" />
                    <ComboBoxItem Content="BOX 9" />
                    <ComboBoxItem Content="BOX 10" />
                    <ComboBoxItem Content="CW1" />
                    <ComboBoxItem Content="CW2" />
                    <ComboBoxItem Content="CW3" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <Label Content="Geschwindigkeit" Target="{Binding ElementName=CmbSimulationSpeed}" />
                <ComboBox x:Name="CmbSimulationSpeed" SelectedIndex="1">
                    <ComboBoxItem Content="Langsam" Tag="1.5" />
                    <ComboBoxItem Content="Normal" Tag="1.0" />
                    <ComboBoxItem Content="Schnell" Tag="0.6" />
                </ComboBox>
            </StackPanel>

            <Button x:Name="BtnStartSimulation"
                    Grid.Column="6"
                    Content="Fahrt starten"
                    Click="BtnStartSimulation_Click"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    Foreground="White" />

            <Button x:Name="BtnResetSimulation"
                    Grid.Column="8"
                    Content="Zurücksetzen"
                    Click="BtnResetSimulation_Click"
                    VerticalAlignment="Bottom" />

            <Button x:Name="BtnAutomaticSimulation"
                    Grid.Column="10"
                    Content="Simulation"
                    Click="BtnAutomaticSimulation_Click"
                    VerticalAlignment="Bottom"
                    Background="#E37400"
                    BorderBrush="#E37400"
                    Foreground="White" />

            <Button x:Name="BtnPauseSimulation"
                    Grid.Column="12"
                    Content="Pause"
                    Click="BtnPauseSimulation_Click"
                    IsEnabled="False"
                    VerticalAlignment="Bottom" />

            <Button x:Name="BtnChangeView"
                    Grid.Column="14"
                    Content="Ansicht wechseln"
                    Click="BtnChangeView_Click"
                    VerticalAlignment="Bottom" />
        </Grid>

        <Border Grid.Row="2"
                Background="#202124"
                BorderBrush="#DADCE0"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Viewport3D x:Name="CraneViewport"
                            ClipToBounds="True">
                    <Viewport3D.Camera>
                        <PerspectiveCamera x:Name="SceneCamera"
                                           Position="0,26,40"
                                           LookDirection="0,-23.5,-40"
                                           UpDirection="0,1,0"
                                           FieldOfView="52" />
                    </Viewport3D.Camera>
                    <ModelVisual3D x:Name="SceneVisual" />
                </Viewport3D>

                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="16"
                        Padding="12,8"
                        Background="#D9202124"
                        BorderBrush="#5F6368"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FALCOM KRANANLAGE"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="3D-Simulation"
                                   Foreground="#BDC1C6"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="16"
                        Padding="12,8"
                        Background="#D9202124"
                        BorderBrush="#5F6368"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="TxtSimulationStatus"
                                   Text="Bereit"
                                   Foreground="White"
                                   FontSize="14" />
                        <TextBlock x:Name="TxtCraneCoordinates"
                                   Text="x=12500 mm  y=12000 mm  z=200 mm"
                                   Foreground="#8AB4F8"
                                   FontFamily="Consolas"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="SimulationModeBanner"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="16"
                        Padding="18,9"
                        Background="#E37400"
                        BorderBrush="#FFD180"
                        BorderThickness="2"
                        CornerRadius="4"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtSimulationModeBanner"
                               Text="AUTOMATIK-SIMULATION AKTIV"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="Bold" />
                </Border>

                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Margin="16"
                           Text="Lokale Simulation ohne OPC-Schreibzugriff"
                           Foreground="#E8EAED"
                           FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
