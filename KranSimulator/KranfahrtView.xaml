<UserControl x:Class="KranSimulator.KranfahrtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F5F7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="Quelle" Target="{Binding ElementName=CmbSimulationSource}" />
                <ComboBox x:Name="CmbSimulationSource" SelectedIndex="0">
                    <ComboBoxItem Content="LKW1" />
                    <ComboBoxItem Content="LKW2" />
                    <ComboBoxItem Content="LKW3" />
                    <ComboBoxItem Content="BOX 1" />
                    <ComboBoxItem Content="BOX 2" />
                    <ComboBoxItem Content="BOX 3" />
                    <ComboBoxItem Content="BOX 4" />
                    <ComboBoxItem Content="BOX 5" />
                    <ComboBoxItem Content="BOX 6" />
                    <ComboBoxItem Content="BOX 7" />
                    <ComboBoxItem Content="BOX 8" />
                    <ComboBoxItem Content="BOX 9" />
                    <ComboBoxItem Content="BOX 10" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Label Content="Ziel" Target="{Binding ElementName=CmbSimulationTarget}" />
                <ComboBox x:Name="CmbSimulationTarget" SelectedIndex="10">
                    <ComboBoxItem Content="BOX 1" />
                    <ComboBoxItem Content="BOX 2" />
                    <ComboBoxItem Content="BOX 3" />
                    <ComboBoxItem Content="BOX 4" />
                    <ComboBoxItem Content="BOX 5" />
                    <ComboBoxItem Content="BOX 6" />
                    <ComboBoxItem Content="BOX 7" />
                    <ComboBoxItem Content="BOX 8" />
                    <ComboBoxItem Content="BOX 9" />
                    <ComboBoxItem Content="BOX 10" />
                    <ComboBoxItem Content="CW1" />
                    <ComboBoxItem Content="CW2" />
                    <ComboBoxItem Content="CW3" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <Label Content="Geschwindigkeit" Target="{Binding ElementName=CmbSimulationSpeed}" />
                <ComboBox x:Name="CmbSimulationSpeed" SelectedIndex="1">
                    <ComboBoxItem Content="Langsam" Tag="1.5" />
                    <ComboBoxItem Content="Normal" Tag="1.0" />
                    <ComboBoxItem Content="Schnell" Tag="0.6" />
                </ComboBox>
            </StackPanel>

            <Button x:Name="BtnStartSimulation"
                    Grid.Column="6"
                    Content="Fahrt starten"
                    Click="BtnStartSimulation_Click"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    Foreground="White" />

            <Button x:Name="BtnResetSimulation"
                    Grid.Column="8"
                    Content="Zurücksetzen"
                    Click="BtnResetSimulation_Click"
                    VerticalAlignment="Bottom" />
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#DADCE0"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Viewbox Stretch="Uniform">
                    <Canvas x:Name="PlantCanvas"
                            Width="1080"
                            Height="650"
                            Background="#F8F9FA">
                        <Rectangle Canvas.Left="0"
                                   Canvas.Top="0"
                                   Width="1080"
                                   Height="54"
                                   Fill="#202124" />
                        <TextBlock Canvas.Left="28"
                                   Canvas.Top="15"
                                   Text="FALCOM KRANANLAGE"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="TxtSimulationStatus"
                                   Canvas.Left="790"
                                   Canvas.Top="17"
                                   Width="260"
                                   Text="Bereit"
                                   TextAlignment="Right"
                                   Foreground="#BDC1C6"
                                   FontSize="14" />

                        <Rectangle Canvas.Left="40"
                                   Canvas.Top="86"
                                   Width="1000"
                                   Height="6"
                                   Fill="#5F6368" />
                        <Rectangle Canvas.Left="54"
                                   Canvas.Top="92"
                                   Width="8"
                                   Height="500"
                                   Fill="#9AA0A6" />
                        <Rectangle Canvas.Left="1018"
                                   Canvas.Top="92"
                                   Width="8"
                                   Height="500"
                                   Fill="#9AA0A6" />

                        <Border Canvas.Left="85" Canvas.Top="120" Width="250" Height="76"
                                Background="#E8EAED" BorderBrush="#9AA0A6" BorderThickness="1">
                            <Grid>
                                <Rectangle Width="110" Height="34" Fill="#5F6368" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="LKW1" Foreground="White" FontWeight="Bold" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Border Canvas.Left="415" Canvas.Top="120" Width="250" Height="76"
                                Background="#E8EAED" BorderBrush="#9AA0A6" BorderThickness="1">
                            <Grid>
                                <Rectangle Width="110" Height="34" Fill="#5F6368" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="LKW2" Foreground="White" FontWeight="Bold" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <Border Canvas.Left="745" Canvas.Top="120" Width="250" Height="76"
                                Background="#E8EAED" BorderBrush="#9AA0A6" BorderThickness="1">
                            <Grid>
                                <Rectangle Width="110" Height="34" Fill="#5F6368" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="LKW3" Foreground="White" FontWeight="Bold" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <ItemsControl Canvas.Left="85"
                                      Canvas.Top="230"
                                      Width="910"
                                      Height="190">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="2" Columns="5" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="5"
                                            Background="#FFFFFF"
                                            BorderBrush="#9AA0A6"
                                            BorderThickness="1">
                                        <Grid>
                                            <Rectangle Margin="12,34,12,12" Fill="#D8A657" Opacity="0.8" />
                                            <TextBlock Text="{Binding}"
                                                       Margin="10"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#202124" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.Items>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 1</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 2</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 3</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 4</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 5</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 6</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 7</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 8</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 9</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=System.Runtime">BOX 10</System:String>
                            </ItemsControl.Items>
                        </ItemsControl>

                        <Border Canvas.Left="85" Canvas.Top="500" Width="250" Height="80"
                                Background="#FFFFFF" BorderBrush="#B3261E" BorderThickness="2">
                            <Grid>
                                <Rectangle Margin="24,38,24,10" Fill="#B3261E" Opacity="0.65" />
                                <TextBlock Text="CW1" Margin="12" FontSize="17" FontWeight="Bold" />
                            </Grid>
                        </Border>
                        <Border Canvas.Left="415" Canvas.Top="500" Width="250" Height="80"
                                Background="#FFFFFF" BorderBrush="#B3261E" BorderThickness="2">
                            <Grid>
                                <Rectangle Margin="24,38,24,10" Fill="#B3261E" Opacity="0.65" />
                                <TextBlock Text="CW2" Margin="12" FontSize="17" FontWeight="Bold" />
                            </Grid>
                        </Border>
                        <Border Canvas.Left="745" Canvas.Top="500" Width="250" Height="80"
                                Background="#FFFFFF" BorderBrush="#B3261E" BorderThickness="2">
                            <Grid>
                                <Rectangle Margin="24,38,24,10" Fill="#B3261E" Opacity="0.65" />
                                <TextBlock Text="CW3" Margin="12" FontSize="17" FontWeight="Bold" />
                            </Grid>
                        </Border>

                        <Canvas x:Name="CraneAssembly"
                                Canvas.Left="510"
                                Canvas.Top="68"
                                Width="60"
                                Height="390">
                            <Rectangle Width="60"
                                       Height="44"
                                       Fill="#B3261E"
                                       Stroke="#7A1712"
                                       StrokeThickness="2" />
                            <Rectangle Canvas.Left="8"
                                       Canvas.Top="10"
                                       Width="44"
                                       Height="12"
                                       Fill="#F4F5F7" />
                            <Line x:Name="HoistCable"
                                  X1="30"
                                  Y1="44"
                                  X2="30"
                                  Y2="170"
                                  Stroke="#202124"
                                  StrokeThickness="4" />
                            <Grid x:Name="MagnetAssembly"
                                  Canvas.Left="3"
                                  Canvas.Top="160"
                                  Width="54"
                                  Height="48">
                                <Ellipse Width="54"
                                         Height="34"
                                         VerticalAlignment="Top"
                                         Fill="#5F6368"
                                         Stroke="#202124"
                                         StrokeThickness="2" />
                                <Rectangle Width="26"
                                           Height="18"
                                           VerticalAlignment="Bottom"
                                           Fill="#3C4043" />
                            </Grid>
                            <Rectangle x:Name="ScrapLoad"
                                       Canvas.Left="10"
                                       Canvas.Top="204"
                                       Width="40"
                                       Height="26"
                                       Fill="#D8A657"
                                       Stroke="#8A5B16"
                                       StrokeThickness="1"
                                       Visibility="Collapsed" />
                        </Canvas>

                        <TextBlock Canvas.Left="40"
                                   Canvas.Top="612"
                                   Text="Simulation lokal, ohne OPC-Schreibzugriff"
                                   Foreground="#5F6368"
                                   FontSize="13" />
                    </Canvas>
                </Viewbox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
