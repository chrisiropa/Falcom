<Window x:Class="KranSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KranSimulator"
        Title="Falcom Kran-Simulator"
        Icon="Falke-Transparent.ico"
        Width="1240"
        Height="897"
        MinWidth="1040"
        MinHeight="806"
        Loaded="MainWindow_Loaded"
        WindowStartupLocation="CenterScreen"
        Background="#F4F5F7">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#202124" Padding="24,18">
            <DockPanel>
                <Ellipse x:Name="ConnectionIndicator"
                         DockPanel.Dock="Right"
                         Width="12"
                         Height="12"
                         Margin="12,0,0,0"
                         Fill="#9AA0A6"
                         VerticalAlignment="Center" />
                <Border DockPanel.Dock="Right"
                        Width="104"
                        Height="58"
                        Margin="0,-8,18,-8"
                        Padding="5"
                        Background="White"
                        CornerRadius="3"
                        VerticalAlignment="Center">
                    <Image Source="IROPA.png"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                </Border>
                <StackPanel>
                    <TextBlock Text="FALCOM KRAN-SIMULATOR"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="OPC-UA Testwerkzeug"
                               Foreground="#BDC1C6"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Background="#F4F5F7"
                    BorderThickness="0"
                    Padding="0">
            <TabItem Header="FALCOM Event">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Verbindung" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <Label Content="OPC-UA Endpoint" Target="{Binding ElementName=TxtEndpoint}" />
                            <TextBox x:Name="TxtEndpoint" Text="opc.tcp://localhost:4840" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.ColumnSpan="3" Text="Auftragsdaten" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <Label Content="Auftrag-ID" Target="{Binding ElementName=TxtAuftragId}" />
                                <TextBox x:Name="TxtAuftragId" Text="1" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <Label Content="Kranquelle" Target="{Binding ElementName=CmbQuelle}" />
                                <ComboBox x:Name="CmbQuelle"
                                          DisplayMemberPath="DisplayText"
                                          SelectedValuePath="OpcValue" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <Label Content="Istgewicht (kg)" Target="{Binding ElementName=TxtGewicht}" />
                                <TextBox x:Name="TxtGewicht" Text="555,0" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2">
                                <Label Content="Kranziel" Target="{Binding ElementName=CmbZiel}" />
                                <ComboBox x:Name="CmbZiel"
                                          DisplayMemberPath="DisplayText"
                                          SelectedValuePath="OpcValue" />
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.Column="0">
                                <Label Content="Fehlercode" Target="{Binding ElementName=TxtFehlercode}" />
                                <TextBox x:Name="TxtFehlercode" Text="0" />
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="2">
                                <Label Content="Toleranz" Target="{Binding ElementName=TxtToleranz}" />
                                <TextBox x:Name="TxtToleranz" Text="50,0" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Margin="0,26,0,0">
                            <WrapPanel>
                                <Button x:Name="BtnWriteFalcomEvent"
                                        Content="FALCOM Event schreiben"
                                        Click="BtnWriteFalcomEvent_Click"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="White"
                                        BorderBrush="{StaticResource AccentBrush}" />
                            </WrapPanel>

                            <TextBlock Text="Protokoll" FontSize="16" FontWeight="SemiBold" Margin="0,26,0,10" />
                            <TextBox x:Name="TxtLog"
                                     Height="150"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Visible"
                                     FontFamily="Consolas"
                                     Background="#FFFFFF" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Kranfahrt">
                <local:KranfahrtView />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#E8EAED" Padding="24,10">
            <TextBlock x:Name="TxtStatus" Text="Bereit" Foreground="#5F6368" />
        </Border>
    </Grid>
</Window>
