<Window x:Class="KranSPS_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Falcom Kran-SPS-Simulator"
        Icon="Falke-Transparent.ico"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F4F5F7">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#202124" Padding="24,18">
            <DockPanel>
                <Ellipse x:Name="ConnectionIndicator"
                         DockPanel.Dock="Right"
                         Width="12"
                         Height="12"
                         Margin="12,0,0,0"
                         Fill="#9AA0A6"
                         VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock Text="FALCOM KRAN-SPS-SIMULATOR"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Simulation der späteren SPS-Logik"
                               Foreground="#BDC1C6"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="20"
                    Background="White"
                    BorderBrush="#DADCE0"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Verbindung"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Label Content="OPC-UA Endpoint"
                               Target="{Binding ElementName=TxtEndpoint}" />
                        <TextBox x:Name="TxtEndpoint" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Statusvariable"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Label Content="OPC Node-ID"
                               Target="{Binding ElementName=TxtStatusNode}" />
                        <TextBox x:Name="TxtStatusNode"
                                 FontFamily="Consolas"
                                 Background="#FFFFFF" />
                        <TextBlock x:Name="TxtConfigurationSource"
                                   Margin="0,7,0,0"
                                   Foreground="#5F6368" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="20"
                    Background="White"
                    BorderBrush="#DADCE0"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnWriteStatus"
                            Grid.Column="0"
                            Content="Status"
                            Click="BtnWriteStatus_Click"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Foreground="White"
                            FontWeight="SemiBold" />

                    <StackPanel Grid.Column="2">
                        <Label Content="SPS-Status"
                               Target="{Binding ElementName=CmbStatus}" />
                        <ComboBox x:Name="CmbStatus"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="CmbStatus_SelectionChanged" />
                        <TextBlock x:Name="TxtStatusDescription"
                                   Margin="0,8,0,0"
                                   Foreground="#5F6368"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Protokoll"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <TextBox x:Name="TxtLog"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         Background="White" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#E8EAED" Padding="24,10">
            <TextBlock x:Name="TxtApplicationStatus"
                       Text="Bereit"
                       Foreground="#5F6368" />
        </Border>
    </Grid>
</Window>
