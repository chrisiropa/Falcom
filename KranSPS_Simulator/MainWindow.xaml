<Window x:Class="KranSPS_Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Falcom Kran-SPS-Simulator"
        Icon="Falke-Transparent.ico"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#102A2A">
   <Window.Resources>
      <Style x:Key="Card" TargetType="Border">
         <Setter Property="Background" Value="#163B3B" />
         <Setter Property="CornerRadius" Value="10" />
         <Setter Property="Padding" Value="14" />
         <Setter Property="Margin" Value="8" />
      </Style>
      <Style x:Key="Caption" TargetType="TextBlock">
         <Setter Property="Foreground" Value="#9FD5CF" />
         <Setter Property="FontSize" Value="13" />
      </Style>
      <Style x:Key="Value" TargetType="TextBlock">
         <Setter Property="Foreground" Value="#F4FFFC" />
         <Setter Property="FontSize" Value="18" />
         <Setter Property="FontWeight" Value="SemiBold" />
      </Style>
   </Window.Resources>

   <Grid Margin="16">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="Auto" />
         <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0" Margin="0,0,0,12">
         <Border DockPanel.Dock="Right"
                 Width="104"
                 Height="58"
                 Margin="18,0,0,0"
                 Padding="5"
                 Background="#F4FFFC"
                 CornerRadius="5"
                 VerticalAlignment="Center">
            <Image Source="IROPA.png"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True" />
         </Border>

         <TextBlock x:Name="LastRefreshText"
                    DockPanel.Dock="Right"
                    Foreground="#9FD5CF"
                    VerticalAlignment="Center"
                    FontSize="14" />

         <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="Kran-SPS Simulation"
                       Foreground="#F4FFFC"
                       FontSize="30"
                       FontWeight="Bold" />
            <TextBlock Text="Simulation der Kran-SPS-Signale, Lebenszähler, OPC-Verbindung und Ablauf-Log"
                       Foreground="#9FD5CF"
                       FontSize="14" />
         </StackPanel>
      </DockPanel>

      <UniformGrid Grid.Row="1" Columns="4">
         <Border Style="{StaticResource Card}">
            <Grid>
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
               </Grid.ColumnDefinitions>
               <Ellipse x:Name="OpcLamp" Width="22" Height="22" Fill="#DC2626" Margin="0,4,12,0" />
               <StackPanel Grid.Column="1">
                  <TextBlock Style="{StaticResource Caption}" Text="OPC Tani / Kran-SPS" />
                  <TextBlock x:Name="OpcStatusText" Style="{StaticResource Value}" Text="Unbekannt" />
                  <TextBlock x:Name="OpcStatusDetailText" Style="{StaticResource Caption}" TextWrapping="Wrap" />
               </StackPanel>
            </Grid>
         </Border>

         <Border Style="{StaticResource Card}">
            <Grid>
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
               </Grid.ColumnDefinitions>
               <Ellipse x:Name="FalcomLifeLamp" Width="22" Height="22" Fill="#6B7280" Margin="0,4,12,0" />
               <StackPanel Grid.Column="1">
                  <TextBlock Style="{StaticResource Caption}" Text="Lebenszähler Falcom → SPS" />
                  <TextBlock x:Name="FalcomLifeValueText" Style="{StaticResource Value}" Text="-" />
                  <TextBlock x:Name="FalcomLifeTimeText" Style="{StaticResource Caption}" Text="Noch nicht empfangen" />
               </StackPanel>
            </Grid>
         </Border>

         <Border Style="{StaticResource Card}">
            <Grid>
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
               </Grid.ColumnDefinitions>
               <Ellipse x:Name="SpsLifeLamp" Width="22" Height="22" Fill="#6B7280" Margin="0,4,12,0" />
               <StackPanel Grid.Column="1">
                  <TextBlock Style="{StaticResource Caption}" Text="Lebenszähler SPS → Falcom" />
                  <TextBlock x:Name="SpsLifeValueText" Style="{StaticResource Value}" Text="-" />
                  <TextBlock x:Name="SpsLifeTimeText" Style="{StaticResource Caption}" Text="Noch nicht gesendet" />
               </StackPanel>
            </Grid>
         </Border>

         <Border Style="{StaticResource Card}">
            <StackPanel>
               <TextBlock Style="{StaticResource Caption}" Text="Simulationsstatus" />
               <TextBlock x:Name="SimulationStatusText" Style="{StaticResource Value}" Text="Bereit" />
               <TextBlock x:Name="SimulationDetailText"
                          Style="{StaticResource Caption}"
                          TextWrapping="Wrap"
                          Text="Neue SPS-Logik wird schrittweise ergänzt." />
               <Button x:Name="DemoModeButton"
                       Margin="0,14,0,0"
                       Padding="14,8"
                       Content="Simulation/Demo"
                       Click="DemoModeButton_Click" />
</StackPanel>
         </Border>
      </UniformGrid>

      <TabControl Grid.Row="2"
                  Margin="0,12,0,0"
                  Background="#102A2A"
                  BorderBrush="#2E6F69"
                  Foreground="#F4FFFC">
         <TabItem Header="Ablauf">
            <Border Style="{StaticResource Card}">
               <DockPanel>
                  <TextBlock DockPanel.Dock="Top"
                             Text="Ablauf-Logging"
                             Foreground="#F4FFFC"
                             FontSize="20"
                             FontWeight="SemiBold"
                             Margin="0,0,0,10" />
                  <ListBox x:Name="LogList"
                           Background="#0E3A38"
                           Foreground="#DDFCF6"
                           BorderThickness="0"
                           FontFamily="Consolas"
                           FontSize="12" />
               </DockPanel>
            </Border>
         </TabItem>

         <TabItem Header="OPC">
            <Grid>
               <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="*" />
               </Grid.RowDefinitions>

               <Border Grid.Row="0" Style="{StaticResource Card}">
                  <DockPanel>
                     <TextBlock DockPanel.Dock="Top"
                                Text="OPC Senden"
                                Foreground="#F4FFFC"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />
                     <ListBox x:Name="OpcSendList"
                              Background="#0E3A38"
                              Foreground="#DDFCF6"
                              BorderThickness="0"
                              FontFamily="Consolas"
                              FontSize="12" />
                  </DockPanel>
               </Border>

               <Border Grid.Row="1" Style="{StaticResource Card}">
                  <DockPanel>
                     <TextBlock DockPanel.Dock="Top"
                                Text="OPC Empfang"
                                Foreground="#F4FFFC"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,10" />
                     <ListBox x:Name="OpcReceiveList"
                              Background="#0E3A38"
                              Foreground="#DDFCF6"
                              BorderThickness="0"
                              FontFamily="Consolas"
                              FontSize="12" />
                  </DockPanel>
               </Border>
            </Grid>
         </TabItem>

         <TabItem Header="Events">
            <Border Style="{StaticResource Card}">
               <DockPanel>
                  <TextBlock DockPanel.Dock="Top"
                             Text="Event-Visualisierung"
                             Foreground="#F4FFFC"
                             FontSize="20"
                             FontWeight="SemiBold"
                             Margin="0,0,0,10" />
                  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                     <StackPanel Orientation="Horizontal">
                        <Border Width="360"
                                MinHeight="220"
                                Margin="0,0,14,0"
                                Padding="14"
                                Background="#0E3A38"
                                CornerRadius="8"
                                BorderBrush="#2E6F69"
                                BorderThickness="1">
                           <DockPanel>
                              <StackPanel DockPanel.Dock="Top"
                                          Margin="0,0,0,12">
                                 <TextBlock Text="Event 1"
                                            Foreground="#9FD5CF"
                                            FontSize="13" />
                                 <TextBlock Text="KranfahrtBeendet"
                                            Foreground="#F4FFFC"
                                            FontSize="22"
                                            FontWeight="Bold" />
                                 <TextBlock Text="KRAN_SPS -> FALCOM"
                                            Foreground="#9FD5CF"
                                            FontSize="12" />
                              </StackPanel>

                              <ItemsControl x:Name="KranfahrtBeendetEventItems">
                                 <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                       <Grid Margin="0,4">
                                          <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="Auto" />
                                          </Grid.ColumnDefinitions>
                                          <TextBlock Grid.Column="0"
                                                     Text="{Binding Name}"
                                                     Foreground="#DDFCF6"
                                                     FontSize="15" />
                                          <TextBlock Grid.Column="1"
                                                     Text="{Binding Wert}"
                                                     Foreground="#F4FFFC"
                                                     FontSize="15"
                                                     FontWeight="SemiBold"
                                                     Margin="18,0,0,0" />
                                       </Grid>
                                    </DataTemplate>
                                 </ItemsControl.ItemTemplate>
                              </ItemsControl>
                           </DockPanel>
                        </Border>

                        <Border Width="360"
                                MinHeight="220"
                                Margin="0,0,14,0"
                                Padding="14"
                                Background="#0E3A38"
                                CornerRadius="8"
                                BorderBrush="#2E6F69"
                                BorderThickness="1">
                           <DockPanel>
                              <StackPanel DockPanel.Dock="Top"
                                          Margin="0,0,0,12">
                                 <TextBlock Text="Event 2"
                                            Foreground="#9FD5CF"
                                            FontSize="13" />
                                 <TextBlock Text="KranfahrtAuftrag"
                                            Foreground="#F4FFFC"
                                            FontSize="22"
                                            FontWeight="Bold" />
                                 <TextBlock Text="FALCOM -> KRAN_SPS"
                                            Foreground="#9FD5CF"
                                            FontSize="12" />
                              </StackPanel>

                              <ItemsControl x:Name="KranfahrtAuftragEventItems">
                                 <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                       <Grid Margin="0,4">
                                          <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="Auto" />
                                          </Grid.ColumnDefinitions>
                                          <TextBlock Grid.Column="0"
                                                     Text="{Binding Name}"
                                                     Foreground="#DDFCF6"
                                                     FontSize="15" />
                                          <TextBlock Grid.Column="1"
                                                     Text="{Binding Wert}"
                                                     Foreground="#F4FFFC"
                                                     FontSize="15"
                                                     FontWeight="SemiBold"
                                                     Margin="18,0,0,0" />
                                       </Grid>
                                    </DataTemplate>
                                 </ItemsControl.ItemTemplate>
                              </ItemsControl>
                           </DockPanel>
                        </Border>

                        <Border Width="360"
                                MinHeight="220"
                                Margin="0,0,14,0"
                                Padding="14"
                                Background="#0E3A38"
                                CornerRadius="8"
                                BorderBrush="#2E6F69"
                                BorderThickness="1">
                           <DockPanel>
                              <StackPanel DockPanel.Dock="Top"
                                          Margin="0,0,0,12">
                                 <TextBlock Text="Event 5"
                                            Foreground="#9FD5CF"
                                            FontSize="13" />
                                 <TextBlock Text="KranPosition"
                                            Foreground="#F4FFFC"
                                            FontSize="22"
                                            FontWeight="Bold" />
                                 <TextBlock Text="KRAN_SPS -> FALCOM"
                                            Foreground="#9FD5CF"
                                            FontSize="12" />
                              </StackPanel>

                              <ItemsControl x:Name="KranPositionEventItems">
                                 <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                       <Grid Margin="0,4">
                                          <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="Auto" />
                                          </Grid.ColumnDefinitions>
                                          <TextBlock Grid.Column="0"
                                                     Text="{Binding Name}"
                                                     Foreground="#DDFCF6"
                                                     FontSize="15" />
                                          <TextBlock Grid.Column="1"
                                                     Text="{Binding Wert}"
                                                     Foreground="#F4FFFC"
                                                     FontSize="15"
                                                     FontWeight="SemiBold"
                                                     Margin="18,0,0,0" />
                                       </Grid>
                                    </DataTemplate>
                                 </ItemsControl.ItemTemplate>
                              </ItemsControl>
                           </DockPanel>
                        </Border>
                     </StackPanel>                  </ScrollViewer>
               </DockPanel>
            </Border>
         </TabItem>
      </TabControl>
   </Grid>
</Window>
