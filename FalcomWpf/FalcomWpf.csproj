    <Compile Include="..\DatabaseOrderPoller.cs" Link="Falcom\DatabaseOrderPoller.cs" />
    <Compile Include="..\Enums.cs" Link="Falcom\Enums.cs" />
    <Compile Include="..\Events_Database.cs" Link="Falcom\Events_Database.cs" />
    <Compile Include="..\Events_Kran.cs" Link="Falcom\Events_Kran.cs" />
